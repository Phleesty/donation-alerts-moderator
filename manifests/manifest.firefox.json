{
  "manifest_version": 2,
  "name": "DA Moderator",
  "version": "2.1.0",
  "description": "Звуковые оповещения, выбор кнопки для подтверждения донатов, автоматическое подтверждение донатов",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.donationalerts.com/widget/lastdonations*"
      ],
      "js": [
        "content.js"
      ],
      "css": [
        "modal.css"
      ]
    }
  ],
  "background": {
    "scripts": [
      "background.js"
    ]
  },
  "permissions": [
    "activeTab",
    "tabs",
    "storage",
    "alarms",
    "https://raw.githubusercontent.com/*",
    "https://cdn.jsdelivr.net/*",
    "https://www.youtube.com/*",
    "https://returnyoutubedislikeapi.com/*"
  ],
  "browser_action": {
    "default_icon": "icons/icon48.png",
    "default_title": "DA Moderator",
    "default_popup": "popup.html"
  },
  "web_accessible_resources": [
    "sounds/doorbell.mp3",
    "sounds/sparkle-tone.mp3",
    "sounds/cute-sound.mp3",
    "sounds/moon-drop.mp3",
    "sounds/notification.mp3",
    "sounds/to-the-point.mp3",
    "sounds/old-sound.mp3",
    "fonts/Geologica-Regular.ttf",
    "fonts/Geologica-SemiBold.ttf",
    "fonts/Geologica-Bold.ttf"
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "{876fc4ab-d8ad-4efa-bda7-86d463538ee3}",
      "update_url": "https://raw.githubusercontent.com/phleesty/donation-alerts-moderator/main/updates.json",
      "strict_min_version": "78.0"
    }
  }
}

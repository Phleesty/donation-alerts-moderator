{
  "manifest_version": 3,
  "name": "DA Moderator",
  "version": "2.1.0",
  "description": "Звуковые оповещения, выбор кнопки для подтверждения донатов, автоматическое подтверждение донатов",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.donationalerts.com/widget/lastdonations*"
      ],
      "js": [
        "content.js"
      ],
      "css": [
        "modal.css"
      ]
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "permissions": [
    "activeTab",
    "tabs",
    "storage"
  ],
  "host_permissions": [
    "https://www.youtube.com/*",
    "https://returnyoutubedislikeapi.com/*"
  ],
  "action": {
    "default_icon": "icons/icon48.png",
    "default_title": "DA Moderator",
    "default_popup": "popup.html"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "sounds/doorbell.mp3",
        "sounds/sparkle-tone.mp3",
        "sounds/cute-sound.mp3",
        "sounds/moon-drop.mp3",
        "sounds/notification.mp3",
        "sounds/to-the-point.mp3",
        "sounds/old-sound.mp3",
        "fonts/Geologica-Regular.ttf",
        "fonts/Geologica-SemiBold.ttf",
        "fonts/Geologica-Bold.ttf"
      ],
      "matches": [
        "https://www.donationalerts.com/*"
      ]
    }
  ]
}
